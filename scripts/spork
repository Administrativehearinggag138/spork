#!/usr/bin/env sh
set -eu

SOURCE=$0
while [ -L "$SOURCE" ]; do
  SOURCE_DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
  SOURCE_TARGET=$(readlink "$SOURCE")
  case "$SOURCE_TARGET" in
    /*) SOURCE=$SOURCE_TARGET ;;
    *) SOURCE=$SOURCE_DIR/$SOURCE_TARGET ;;
  esac
done

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
PROJECT_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)

export SPORK_HOME="${SPORK_HOME:-$HOME/.spork}"
export PYTHONPATH="$PROJECT_ROOT/src:${PYTHONPATH:-}"
exec python3 -m spork.cli "$@"
